# ===== Anthropic =====
ANTHROPIC_API_KEY=
MODEL_PLANNER=claude-haiku-4-5
MODEL_REASONER=claude-sonnet-4-6

# ===== Alpaca =====
# Crea claves de PAPER en https://app.alpaca.markets/ (sección Paper Trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper trading activado por defecto. NO operar con dinero real salvo que
# sepas exactamente lo que haces.
ALPACA_PAPER=true

# Doble cerrojo: para operar con dinero real NO basta ALPACA_PAPER=false,
# además hay que poner esto a true. Si es false, las ordenes reales se bloquean.
ENABLE_LIVE_TRADING=false

# ===== Parámetros del bot =====
DEFAULT_SCORE_THRESHOLD=7.5
DEFAULT_MAX_POSITION_PCT=0.05
DEFAULT_INTERVAL_MINUTES=60
DEFAULT_MAX_OPEN_POSITIONS=10

# ===== Caché / almacenamiento =====
CACHE_TTL_HOURS=12
CACHE_DB_PATH=data/cache.duckdb
LOG_DB_PATH=data/trades.duckdb
